{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev: Dhikr Tools",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "compile-dhikr-ext"
    }
  ]
}
