---
import ContentRenderer from "@/components/astro/ContentRenderer.astro";
import { contentModules } from "@/config/content-loader";
import { pageConfigs } from "@/config/page-config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { BaseRecitationModel } from "@/models/recitation";

export function getStaticPaths() {
  return pageConfigs
    .filter((config) => {
      // Home page is handled by index.astro
      if (config.path === "") return false;
      if (!contentModules.has(config.contentImportPath)) {
        console.warn(
          `Skipping "${config.path}" — content file missing: ${config.contentImportPath}.ts`,
        );
        return false;
      }
      return true;
    })
    .map((config) => ({
      params: { slug: config.path || undefined },
      props: {
        title: config.title,
        description: config.description,
        // biome-ignore lint/style/noNonNullAssertion: existence verified by filter above
        content: contentModules.get(config.contentImportPath)!,
        path: config.path,
      },
    }));
}

interface Props {
  title: string;
  description?: string;
  content: BaseRecitationModel[];
  path: string;
}

const { title, description, content, path } = Astro.props;
---

<BaseLayout title={title} description={description} pagePath={path}>
  <ContentRenderer items={content} pagePath={path} />
</BaseLayout>
