---
import { SURAH_NAMES } from "@/data/shared/surah-names";
import {
  DHIKR_COUNTER_THRESHOLD,
  DhikrEntryModel,
  type DhikrModel,
  QuranDhikrEntryModel,
} from "@/models/recitation";
import DhikrEntry from "./DhikrEntry.astro";
import QuranEntry from "./QuranEntry.astro";

interface Props {
  model: DhikrModel;
  index: number;
  elementId?: string;
}

const { model, index, elementId: providedId } = Astro.props;

const modelRepeat = model.repeat ?? 1;
const showModelCounter = modelRepeat > DHIKR_COUNTER_THRESHOLD;
const showModelRepeatText = modelRepeat > 1;

const elementId = providedId ?? `${index + 1}`;
const makeKey = (suffix?: number) => {
  return suffix !== undefined ? `${elementId}-${suffix}` : elementId;
};
---

<div class="dhikr-container" id={elementId}>
  {model.instruction && <p class="instruction">{model.instruction}</p>}
  {showModelRepeatText && <p class="instruction dhikr-repeat">(Repeat the following x{modelRepeat})</p>}
  {model.entries.map((entry, i) => {
    if (entry instanceof QuranDhikrEntryModel) {
      const surahName = SURAH_NAMES.get(entry.surah) ?? `Surah ${entry.surah}`;
      return (
        <>
          <QuranEntry
            entry={entry}
            openingBrace={true}
            closingBrace={true}
            repeatText=""
          />
          <kp-footnote type="quran">
            Surah {surahName} ({entry.surah}):{entry.verse}
          </kp-footnote>
        </>
      );
    }
    return <DhikrEntry entry={entry as DhikrEntryModel} storageKey={makeKey(i)} />;
  })}
  {showModelCounter && (
    <kp-dhikr-counter
      target={modelRepeat}
      storagekey={makeKey()}
    ></kp-dhikr-counter>
  )}
</div>

<style>
  .dhikr-repeat {
    text-align: center;
    margin-top: 0.5em;
    font-style: italic;
  }

</style>
