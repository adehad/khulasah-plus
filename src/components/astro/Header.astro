---
import { pageConfigs } from "@/config/page-config";
import { resolveBasePath } from "@/utils/paths";
import InlineIcon from "./InlineIcon.astro";

interface Props {
  pagePath: string;
}

const { pagePath } = Astro.props;

// Build a lookup map: path → title
const pathTitleMap = new Map(pageConfigs.map((c) => [c.path, c.title]));

interface Breadcrumb {
  text: string;
  href: string;
}

function buildBreadcrumbs(currentPath: string): Breadcrumb[] {
  const homeTitle = pathTitleMap.get("") ?? "Home";
  const crumbs: Breadcrumb[] = [
    { text: homeTitle, href: resolveBasePath("/") },
  ];

  if (!currentPath) return crumbs;

  const segments = currentPath.split("/").filter(Boolean);
  let accumulated = "";

  for (const segment of segments) {
    accumulated += (accumulated ? "/" : "") + segment;
    const title = pathTitleMap.get(accumulated);
    if (title) {
      crumbs.push({ text: title, href: resolveBasePath(`/${accumulated}/`) });
    }
  }

  return crumbs;
}

const breadcrumbs = buildBreadcrumbs(pagePath);
const isHome = !pagePath;
const homeCrumb = breadcrumbs[0];
const currentCrumb =
  breadcrumbs.length > 1 ? breadcrumbs[breadcrumbs.length - 1] : null;
const intermediateCrumbs = breadcrumbs.slice(1, breadcrumbs.length - 1);
---

<header>
  <nav aria-label="Breadcrumb" class="breadcrumb">
    <a href={isHome ? "#" : homeCrumb.href} class="breadcrumb-link">
      <InlineIcon name="house" size="1.2rem" label="Home" />
    </a>

    {intermediateCrumbs.length > 0 && (
      <>
        <span class="separator" aria-hidden="true">/</span>
        <sl-dropdown>
          <sl-button slot="trigger" size="small" caret>{intermediateCrumbs.length}</sl-button>
          <sl-menu>
            {intermediateCrumbs.map(crumb => (
              <a href={crumb.href}><sl-menu-item>{crumb.text}</sl-menu-item></a>
            ))}
          </sl-menu>
        </sl-dropdown>
      </>
    )}

    {currentCrumb && (
      <>
        <span class="separator" aria-hidden="true">/</span>
        <span class="breadcrumb-current">{currentCrumb.text}</span>
        <sl-dropdown id="toc-dropdown" style="display: none;">
          <button slot="trigger" class="toc-trigger">
            <InlineIcon name="chevron-double-down" size="1rem" label="Table of contents" />
          </button>
          <sl-menu id="toc-menu"></sl-menu>
        </sl-dropdown>
      </>
    )}
  </nav>

  <div class="header-actions">
    <kp-search-button></kp-search-button>
    <settings-menu></settings-menu>
    <theme-switcher></theme-switcher>
  </div>

  <kp-audio-player></kp-audio-player>
</header>

<style>
  header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    background: var(--sl-color-neutral-0);
    padding: 12px;
    padding-top: calc(4px + env(titlebar-area-y, 0));
    padding-bottom: 0px;
    min-height: env(titlebar-area-height, 30px);
    -webkit-app-region: drag;
    z-index: 100;
    position: sticky;
    top: 0;
    flex-shrink: 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--sl-font-size-small);
    -webkit-app-region: no-drag;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    color: var(--sl-color-neutral-600);
    text-decoration: none;
  }

  .breadcrumb-link:hover {
    color: var(--sl-color-primary-600);
  }

  .separator {
    color: var(--sl-color-neutral-500);
    user-select: none;
  }

  .breadcrumb-current {
    color: var(--sl-color-neutral-950);
    font-weight: var(--sl-font-weight-semibold);
  }

  .toc-trigger {
    display: inline-flex;
    align-items: center;
    background: none;
    border: none;
    padding: 0.25rem;
    cursor: pointer;
    color: var(--sl-color-neutral-600);
    transform: translateY(0.15rem);
  }

  .toc-trigger:hover {
    color: var(--sl-color-primary-600);
  }

  .header-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    -webkit-app-region: no-drag;
  }

  kp-audio-player {
    flex-shrink: 0;
  }

  kp-audio-player:not([collapsed]) {
    width: 100%;
    order: 1;
  }

  /* Style links inside dropdown menu items */
  a {
    text-decoration: none;
    color: inherit;
  }

  @media (max-width: 420px) {
    header {
      justify-content: center;
      gap: 0.5rem;
    }

    .breadcrumb {
      width: 100%;
      display: flex;
      justify-content: center;
    }

    .header-actions {
      width: 100dvw;
      justify-content: center;
    }
  }
</style>
